# ── AI Model ──────────────────────────────────────────────
# Option A: Use Anthropic API directly (recommended for prototyping)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: Use vLLM (self-hosted open-source model)
# Uncomment below and comment out ANTHROPIC_API_KEY to switch
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3-8b-instruct

# ── Databases ─────────────────────────────────────────────
# PostgreSQL — long-term storage (conversation history, users)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agentosdb

# Redis — short-term session cache
REDIS_URL=redis://localhost:6379

# ── Observability ─────────────────────────────────────────
# Logfire — get token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=your_logfire_token_here

# ── App ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret_key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
